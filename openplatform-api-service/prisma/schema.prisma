// Prisma Schema for Cregis OpenPlatform
// MySQL Database

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ============================================
// IsvDeveloper - ISV开发者账号表（原Developer）
// ============================================
model IsvDeveloper {
  /// 开发者唯一标识 UUID
  id           String   @id @default(uuid())
  /// 开发者邮箱（唯一）
  email        String   @unique
  /// 密码哈希
  passwordHash String   @map("password_hash")
  /// 企业名称（ISV公司名称）
  legalName           String   @map("legal_name")
  /// 统一社会信用代码
  registrationNumber  String?  @map("registration_number")
  /// 注册地（国家/地区）
  jurisdiction        String?  @map("jurisdiction")
  /// 成立日期
  dateOfIncorporation String?  @map("date_of_incorporation")
  /// 注册地址
  registeredAddress   String?  @map("registered_address")
  /// 官网
  website             String?
  /// UBO信息（受益所有人）
  uboInfo             Json?    @map("ubo_info")
  /// KYB审核状态: pending(待审核), approved(已通过), rejected(已拒绝)
  kybStatus           String   @default("pending") @map("kyb_status")
  /// KYB审核时间
  kybReviewedAt       DateTime? @map("kyb_reviewed_at")
  /// KYB审核人ID
  kybReviewedBy       String?   @map("kyb_reviewed_by")
  /// 账号状态: active(正常), suspended(停用), deleted(已删除)
  status       String   @default("active")
  /// 创建时间
  createdAt    DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt    DateTime @updatedAt @map("updated_at")

  applications       Application[]
  isvUsers            IsvUser[]
  bindings            Binding[]
  endpointPermissions EndpointPermission[]

  @@map("isv_developer")
}

// ============================================
// Application - 应用信息表
// ============================================
model Application {
  /// 应用唯一标识 UUID
  id            String   @id @default(uuid())
  /// 关联的ISV开发者ID
  isvDeveloperId   String   @map("isv_developer_id")
  /// 应用名称
  appName       String   @map("app_name")
  /// 应用描述
  appDescription String?  @map("app_description")
  /// 应用密钥
  appSecret     String   @map("app_secret")
  /// 应用状态: active(正常), suspended(停用), deleted(已删除)
  status        String   @default("active")
  /// 创建时间
  createdAt    DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt    DateTime @updatedAt @map("updated_at")

  isvDeveloper   IsvDeveloper    @relation(fields: [isvDeveloperId], references: [id], onDelete: Cascade)
  oauthResources OauthResource[]
  webhooks       Webhook[]
  apiLogs        ApiLog[]
  metrics        Metric[]

  @@index([isvDeveloperId])
  @@map("applications")
}

// ============================================
// OauthResource - OAuth资源授权表（替换原Authorization）
// 用于存储用户对应用的授权信息，包括资源访问权限
// ============================================
model OauthResource {
  /// 授权唯一标识 UUID
  id           String   @id @default(uuid())
  /// 关联的应用ID
  appId       String   @map("app_id")
  /// 用户ID
  userId      String   @map("user_id")
  /// 资源键（替换原enterpriseId），可关联企业或其他资源
  resourceKey String?  @map("resource_key")
  /// 授权时间
  authorizedAt DateTime @default(now()) @map("authorized_at")
  /// 授权过期时间
  expiresAt   DateTime? @map("expires_at")
  /// 授权状态: active(有效), revoked(已撤销), expired(已过期)
  status      String   @default("active")
  /// 创建时间
  createdAt   DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt   DateTime @updatedAt @map("updated_at")

  application Application    @relation(fields: [appId], references: [id], onDelete: Cascade)
  enterprise  IsvEnterprise? @relation(fields: [resourceKey], references: [id], onDelete: SetNull)

  @@unique([appId, userId])
  @@index([resourceKey])
  @@map("oauth_resources")
}

// ============================================
// Webhook - Webhook配置表
// ============================================
model Webhook {
  /// Webhook唯一标识 UUID
  id          String   @id @default(uuid())
  /// 关联的应用ID
  appId       String   @map("app_id")
  /// Webhook回调URL
  url         String
  /// Webhook密钥（用于签名验证）
  secret      String?
  /// 订阅的事件类型列表
  eventTypes  Json     @map("event_types")
  /// 是否启用
  isActive    Boolean  @default(true) @map("is_active")
  /// 创建时间
  createdAt   DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt   DateTime @updatedAt @map("updated_at")

  application Application @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId])
  @@map("webhooks")
}

// ============================================
// ApiLog - API调用日志表
// ============================================
model ApiLog {
  /// 日志唯一标识 UUID
  id              String   @id @default(uuid())
  /// 分布式追踪ID
  traceId         String?  @map("trace_id")
  /// 关联的应用ID
  appId           String   @map("app_id")
  /// 请求端点
  endpoint        String
  /// 请求方法
  method          String
  /// 请求头JSON
  requestHeaders  Json?    @map("request_headers")
  /// 请求体JSON
  requestBody    Json?    @map("request_body")
  /// 响应状态码
  responseStatus  Int?     @map("response_status")
  /// 响应体JSON
  responseBody    Json?    @map("response_body")
  /// 响应时间（毫秒）
  responseTime    Int?     @map("response_time")
  /// 客户端IP地址
  ipAddress       String?  @map("ip_address")
  /// 客户端User-Agent
  userAgent       String?  @map("user_agent")
  /// 创建时间
  createdAt       DateTime @default(now()) @map("created_at")

  application    Application @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, createdAt])
  @@index([traceId])
  @@map("api_logs")
}

// ============================================
// Metric - 指标数据表
// ============================================
model Metric {
  /// 指标唯一标识 UUID
  id           String   @id @default(uuid())
  /// 关联的应用ID
  appId        String   @map("app_id")
  /// 指标类型（如 api_calls, revenue 等）
  metricType   String   @map("metric_type")
  /// 指标值
  metricValue  Decimal? @map("metric_value") @db.Decimal(20, 2)
  /// 统计周期开始时间
  periodStart  DateTime @map("period_start")
  /// 统计周期结束时间
  periodEnd    DateTime @map("period_end")
  /// 创建时间
  createdAt    DateTime @default(now()) @map("created_at")

  application  Application @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@index([appId, periodStart])
  @@index([metricType])
  @@map("metrics")
}

// ============================================
// Trace - 分布式追踪表
// ============================================
model Trace {
  /// 追踪记录唯一标识 UUID
  id            String   @id @default(uuid())
  /// 追踪ID
  traceId       String   @map("trace_id")
  /// 关联的应用ID
  appId         String?  @map("app_id")
  /// 服务名称
  serviceName   String?  @map("service_name")
  /// 操作名称
  operationName String?  @map("operation_name")
  /// Span ID
  spanId        String?  @map("span_id")
  /// 父Span ID
  parentSpanId  String?  @map("parent_span_id")
  /// 开始时间
  startTime     DateTime @map("start_time")
  /// 结束时间
  endTime       DateTime? @map("end_time")
  /// 持续时间（毫秒）
  duration      Int?
  /// 状态: pending(进行中), completed(已完成), error(错误)
  status        String   @default("pending")
  /// 标签JSON
  tags          Json?
  /// 日志JSON
  logs          Json?
  /// 创建时间
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([traceId])
  @@index([appId])
  @@index([startTime])
  @@map("traces")
}

// ============================================
// IsvUser - ISV用户表
// ============================================
model IsvUser {
  /// 用户唯一标识 UUID
  id           String   @id @default(uuid())
  /// 关联的ISV开发者ID
  isvDeveloperId String  @map("isv_developer_id")
  /// 用户邮箱（唯一）
  email        String   @unique
  /// 密码哈希
  passwordHash String?  @map("password_hash")
  /// 用户姓名
  name         String?
  /// 手机号
  phone        String?
  /// 角色: owner(所有者), developer(开发者)
  role         String   @default("developer")
  /// 账号状态: active(正常), inactive(未激活), suspended(停用)
  status       String   @default("inactive")
  /// 允许访问的应用ID列表
  allowedApplications Json? @map("allowed_applications")
  /// 创建时间
  createdAt    DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt    DateTime @updatedAt @map("updated_at")

  isvDeveloper IsvDeveloper @relation(fields: [isvDeveloperId], references: [id], onDelete: Cascade)

  @@index([isvDeveloperId])
  @@index([email])
  @@map("isv_users")
}

// ============================================
// Binding - 绑定关系表
// ============================================
model Binding {
  /// 绑定唯一标识 UUID
  id              String   @id @default(uuid())
  /// 关联的ISV开发者ID
  isvDeveloperId  String   @map("isv_developer_id")
  /// 绑定类型: bank_account, crypto_wallet, etc.
  bindingType     String   @map("binding_type")
  /// 绑定名称
  name            String?
  /// 绑定账户标识
  accountId       String?  @map("account_id")
  /// 绑定账户详情（JSON）
  accountDetail   Json?    @map("account_detail")
  /// 绑定状态: active(有效), suspended(暂停), removed(已解除)
  status          String   @default("active")
  /// 绑定时间
  boundAt         DateTime @default(now()) @map("bound_at")
  /// 创建时间
  createdAt       DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt       DateTime @updatedAt @map("updated_at")

  isvDeveloper    IsvDeveloper @relation(fields: [isvDeveloperId], references: [id], onDelete: Cascade)

  @@index([isvDeveloperId])
  @@index([bindingType])
  @@map("bindings")
}

// ============================================
// EndpointPermission - 端点权限表
// ============================================
model EndpointPermission {
  /// 权限唯一标识 UUID
  id           String   @id @default(uuid())
  /// 关联的ISV开发者ID
  isvDeveloperId String @map("isv_developer_id")
  /// API端点路径
  endpoint     String
  /// HTTP方法: GET, POST, PUT, DELETE
  method       String
  /// 权限级别: read, write, admin
  permission   String   @default("read")
  /// 是否启用
  isEnabled    Boolean  @default(true) @map("is_enabled")
  /// 创建时间
  createdAt    DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt    DateTime @updatedAt @map("updated_at")

  isvDeveloper IsvDeveloper @relation(fields: [isvDeveloperId], references: [id], onDelete: Cascade)

  @@unique([isvDeveloperId, endpoint, method])
  @@index([isvDeveloperId])
  @@map("endpoint_permissions")
}

// ============================================
// Admin - 管理员表
// ============================================
model Admin {
  /// 管理员唯一标识 UUID
  id           String   @id @default(uuid())
  /// 管理员邮箱（唯一）
  email        String   @unique
  /// 密码哈希
  passwordHash String   @map("password_hash")
  /// 管理员姓名
  name         String?
  /// 角色: super_admin, admin, operator, viewer
  role         String   @default("viewer")
  /// 账号状态: active(正常), suspended(停用), deleted(已删除)
  status       String   @default("active")
  /// 最后登录时间
  lastLoginAt  DateTime? @map("last_login_at")
  /// 创建时间
  createdAt    DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@map("admins")
}
